# 可选：连接 Supabase 云端题库、模型偏好同步与 AI 生成（未配置时仍可预览 /exam/demo 静态 MPG）
# 未配置 Supabase 时，生成的试卷会写入本机 data/local-exams/<uuid>.json（重启服务后仍在试卷库可见）
# 配置后请在 Supabase 执行 supabase/migrations 下的 SQL（含 exams / ai_settings 等表）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 可选：线下导入附图写入 Supabase Storage（公开可读桶）。不设则写入 apps/web/public/import-figures/
# Dashboard → Storage → 新建桶 → Policies 允许 public read；填写桶名后服务端优先上传并返回公开 URL
# MPG_IMPORT_FIGURES_BUCKET=import-figures

# 可选：Postgres 直连串（用于 npm run db:apply 或设置页「执行迁移」；来自 Supabase → Database → Connection string URI）
# DATABASE_URL=postgresql://postgres.[project-ref]:[PASSWORD]@...pooler.supabase.com:6543/postgres
# 需要时允许从设置页触发迁移（勿在生产环境误开）
# ALLOW_UI_DB_MIGRATIONS=true
# 若连接池 SSL 校验失败可尝试：DATABASE_SSL_NO_VERIFY=true

# 云端 AI：设置页选「云端」时，服务端由此密钥调用 Lovable Gateway（勿提交真实密钥）
LOVABLE_API_KEY=

# 客户端 Supabase（Vite 打包进前端）：「教育 OS」登录、浏览器直连 Auth 必填；须与服务端 SUPABASE_URL 同一项目
# Dashboard → Project Settings → API：Project URL → VITE_SUPABASE_URL；anon public → VITE_SUPABASE_PUBLISHABLE_KEY（勿用 service_role）
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# 可选：覆盖 MySQL 密码本地加密主密钥（优先级高于自动生成的 data/mysql-password-master.key）
# 不设则首次在设置页「保存连接」时会在 data/ 生成本机密钥文件；与运维统一密钥时再用此项（openssl rand -base64 32）
# MYSQL_PASSWORD_ENC_KEY=

# 可选：本地 Piper TTS（听力音频）。设为 .onnx 模型绝对路径后，生成听力优先用 Piper；未设时在 macOS 仍用内置 say。详见 docs/listening-piper-setup.md
# 可选：HTTPS 上由贵机构托管的「历年试卷目录」JSON（与 data/remote-paper-catalog.json 结构相同，按 id 合并）
# 正文须自行依法取得并在清单中用 plainText 或 textUrl（UTF-8 纯文本）提供；应用不会自动爬取真题网站
# MPG_REMOTE_IMPORT_CATALOG_URL=https://your-cdn.example.com/exam-catalog.json
# MPG_PIPER_MODEL=
# MPG_PIPER_BIN=
# MPG_PIPER_LIB_PATH=
# 可选：听力选项词间停顿秒数（默认 2.3；say 精确静音，Piper 近似停顿）
# MPG_LISTENING_WORD_GAP_SEC=2.3

# 可选：导入线下卷页「外网检索」——自备 Tavily 或 Brave Search API（不内置爬取第三方题库）
# 也可在应用「设置 → 模型与接口」填写密钥（仅存本机浏览器，请求时传给服务端；与本节 env 叠加，表单优先）
# MPG_WEB_SEARCH_PROVIDER=auto
# MPG_TAVILY_API_KEY=
# MPG_BRAVE_SEARCH_API_KEY=

# 可选：API 网关根 URL（线下导入图片时 Server Fn 优先 POST /api/v1/ocr/image；未配置则仅用浏览器 OCR）
# 本地 Docker 栈见 npm run docker:stack：网关默认映射端口见 infrastructure/docker/docker-compose.yml
# --- 可选：线下导入「双轨 + 闸门」（默认关闭；不改变轨 A：OCR 全文 → LLM 整理）---
# 设为 1 后，导入对话框可勾选「双轨诊断」：不替换整理结果，仅生成轨 B 占位 metadata。
# MPG_IMPORT_DUAL_TRACK_GATE=1
# 子闸门：在勾选双轨诊断时，将占位 layout AST 写入仓库根 data/import-layout-stubs/<examId>.json
# MPG_IMPORT_LAYOUT_AST_PERSIST=1

# 线下导入 OCR 仅 GOT-OCR 2.0（Docker got-ocr-service）；前端引擎固定为 got

# 线下导入：设为 1 则默认「纯 OCR、不落盘 import-figures」（semantic-only；无 authoritative figure registry）
# OFFLINE_IMPORT_OCR_ONLY=1

# 网关根 URL（线下导入 Server Fn 调 OCR 用）：
# - 浏览器走本机 Vite http://localhost:8080 且已 npm run docker:stack:detach 时，推荐：
# MPG_GATEWAY_URL=http://127.0.0.1:8080
#   （Vite 会把 /api/v1 代理到 8090；见 apps/web/vite.config.ts）
# - 浏览器走 Docker 统一入口 http://localhost:8090 时：
# MPG_GATEWAY_URL=http://localhost:8090
# 可选：网关 OCR 等待时间（毫秒），冷启动/大模型易超 2 分钟；默认 600000（10 分钟）
# MPG_GATEWAY_OCR_TIMEOUT_MS=600000
# 设为 0 可关闭线下卷 OCR 后的「汉字间空格合并」预处理（默认开启）
# MPG_OCR_COLLAPSE_CJK_SPACE=0
# OCR 微服务（Docker ocr-service）：YOLO 未检出几何图时启用右栏启发式框（阶段 C）
# 数学卷本地 OCR 调优（EXAM_OCR_MIN_SIDE_PX、PADDLE_DET_LIMIT_SIDE_LEN 等）见 docs/architecture/local-ocr-optimization.md
# YOLO_HEURISTIC_FALLBACK=true
# HEURISTIC_DIAGRAM_RIGHT_RATIO=0.48

# --- 可选：与 Open Notebook 松耦合（独立部署其 FastAPI，默认 :5055）---
# 配置后「导入线下试卷」对话框可「同步预览到 Open Notebook」；未配置则隐藏该区块
# MPG_OPEN_NOTEBOOK_API_BASE_URL=http://127.0.0.1:5055
# 与对方 OPEN_NOTEBOOK_PASSWORD 一致时填写（Bearer）
# MPG_OPEN_NOTEBOOK_PASSWORD=
# 可选：写入指定笔记本 id
# MPG_OPEN_NOTEBOOK_NOTEBOOK_ID=

# --- 可选：抽取合并后的 HTTP 正文增强（自建适配器，如 content-core 封装）---
# POST JSON { "text", "source": "mpg-offline-import" } → { "text" } 或 { "content" }
# MPG_PLAINTEXT_EXTRACT_URL=
# MPG_PLAINTEXT_EXTRACT_TOKEN=

# --- 教材章节目录（MySQL curriculum_catalog_*）：脚本 npm run curriculum-catalog:import ---
# 远程清单 UTF-8 JSON（结构与 examples/v1/curriculum-catalog.sample.json 一致）；不设则用 data/curriculum-catalog.json 或命令行路径
# MPG_CURRICULUM_CATALOG_URL=https://your-cdn.example.com/curriculum-catalog.json
# 可选：拉取 Authorization Bearer
# MPG_CURRICULUM_CATALOG_FETCH_TOKEN=
# 可选：导入后把「本次 JSON 未出现的」series 全部 active=0（慎用，多源并行时不要开）
# MPG_CURRICULUM_CATALOG_DEACTIVATE_OTHERS=0
# 可选：CI/cron 直连 MySQL（不设则读 data/mysql-connection.json）
# MPG_MYSQL_HOST=
# MPG_MYSQL_PORT=3306
# MPG_MYSQL_USER=
# MPG_MYSQL_PASSWORD=
# MPG_MYSQL_DATABASE=
