{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zhixue.local/schemas/contracts/v1/ocr-result.json",
  "title": "OcrExtractResult",
  "type": "object",
  "required": ["engine", "text"],
  "properties": {
    "engine": { "type": "string", "description": "ocr | paddleocr | tesseract | stub" },
    "text": { "type": "string" },
    "blocks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "bbox": { "type": "array", "items": { "type": "number" }, "minItems": 4, "maxItems": 4 },
          "text": { "type": "string" },
          "confidence": { "type": "number" }
        }
      }
    },
    "layout": { "type": ["object", "null"] },
    "job_id": { "type": ["string", "null"] }
  }
}
