{
  "name": "@zhixue/web",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite dev",
    "dev:clean": "rm -rf node_modules/.vite && vite dev",
    "build": "vite build && node scripts/ensure-server-preview-entry.mjs",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "electron": "electron .",
    "desktop": "npm run build && electron .",
    "desktop:dmg": "npm run build && electron-builder --mac dmg",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "diagram-ir:corpus:baseline": "tsx scripts/write-diagram-ir-corpus-baseline.ts",
    "diagram-ir:bench": "tsx scripts/run-diagram-ir-bench.ts",
    "figure-link:bench": "vitest run src/lib/figureLinkTraceCorpus.shared.test.ts",
    "import-pipeline:bench": "vitest run src/lib/importPipelineBench.shared.test.ts src/lib/importFailureTaxonomy.shared.test.ts src/lib/importPipelineDualRun.shared.test.ts && tsx scripts/run-import-pipeline-bench.ts",
    "import-pipeline:dual-run": "vitest run src/lib/importPipelineDualRun.shared.test.ts src/lib/importPipelineDualRunGovernance.shared.test.ts && tsx scripts/run-import-pipeline-dual-run.ts",
    "import-pipeline:taxonomy-coverage": "tsx scripts/report-import-pipeline-taxonomy-coverage.ts",
    "inspect:semantic-lineage": "tsx scripts/inspect-semantic-lineage.ts",
    "inspect:reading-flow": "tsx scripts/inspect-reading-flow.ts",
    "inspect:pagination-flow": "tsx scripts/inspect-pagination-flow.ts",
    "pagination-telemetry:snapshot": "tsx scripts/write-pagination-telemetry-snapshot.ts",
    "pagination-telemetry:compare": "tsx scripts/compare-pagination-telemetry-snapshots.ts",
    "inspect:negotiation-flow": "tsx scripts/inspect-negotiation-flow.ts",
    "negotiation-telemetry:snapshot": "tsx scripts/write-negotiation-telemetry-snapshot.ts",
    "negotiation-telemetry:compare": "tsx scripts/compare-negotiation-telemetry-snapshots.ts",
    "negotiation-telemetry:compare-resilience": "tsx scripts/compare-negotiation-resilience-snapshots.ts",
    "inspect:cross-medium-parity": "tsx scripts/inspect-cross-medium-parity.ts",
    "cross-medium-parity:snapshot": "tsx scripts/write-cross-medium-parity-snapshot.ts",
    "cross-medium-parity:compare": "tsx scripts/compare-cross-medium-parity-snapshots.ts",
    "projection-fidelity:snapshot": "tsx scripts/write-projection-fidelity-snapshot.ts",
    "projection-fidelity:compare": "tsx scripts/compare-projection-fidelity-snapshots.ts",
    "cognitive-telemetry:snapshot": "tsx scripts/write-cognitive-telemetry-snapshot.ts",
    "cognitive-telemetry:compare": "tsx scripts/compare-cognitive-telemetry-snapshots.ts",
    "semantic-telemetry:snapshot": "tsx scripts/write-semantic-telemetry-snapshot.ts",
    "semantic-telemetry:compare": "tsx scripts/compare-semantic-telemetry-snapshots.ts",
    "governance:generic-exam-content": "node scripts/check-generic-exam-content-policy.mjs",
    "governance:epl-ast-contract": "node scripts/check-epl-ast-contract.mjs",
    "governance:projection-purity": "node scripts/check-epl-ast-contract.mjs && vitest run src/lib/projectionPurityContract.shared.test.ts src/lib/projectionPrimitivesContract.shared.test.ts",
    "cleanup:legacy-q24-shim": "node scripts/remove-legacy-q24-shim.mjs"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.25.5",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/supabase-js": "^2.105.1",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.83.0",
    "@tanstack/react-router": "^1.168.0",
    "@tanstack/react-start": "^1.167.14",
    "@tanstack/router-plugin": "^1.167.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "html2canvas": "^1.4.1",
    "input-otp": "^1.4.2",
    "jsonrepair": "^3.14.0",
    "jspdf": "^4.2.1",
    "katex": "^0.16.45",
    "lucide-react": "^0.575.0",
    "mammoth": "^1.12.0",
    "mysql2": "^3.22.3",
    "pdfjs-dist": "^5.7.284",
    "pg": "^8.20.0",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-katex": "^3.1.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.6.5",
    "react-syntax-highlighter": "^16.1.1",
    "recharts": "^2.15.4",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tesseract.js": "^7.0.0",
    "tw-animate-css": "^1.3.4",
    "vaul": "^1.1.2",
    "vite-tsconfig-paths": "^6.0.2",
    "xlsx": "^0.18.5",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@lovable.dev/vite-tanstack-config": "^1.4.0",
    "@types/node": "^22.16.5",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/react-katex": "^3.0.4",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.0.4",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "eslint": "^9.32.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^15.15.0",
    "prettier": "^3.7.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "app.zhixue.math-paper-generator",
    "productName": "知学试卷",
    "copyright": "Copyright © zhixue",
    "directories": {
      "output": "../../release"
    },
    "files": [
      "electron/main.mjs",
      "package.json"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "dist",
        "to": "app-root/dist"
      },
      {
        "from": "../../node_modules",
        "to": "app-root/node_modules"
      },
      {
        "from": "package.json",
        "to": "app-root/package.json"
      },
      {
        "from": "vite.config.ts",
        "to": "app-root/vite.config.ts"
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
