# 无 Supabase 时服务端写入的本地简易题库
data/local-exams/*.json
data/import-layout-stubs/*.json
!data/local-exams/.gitkeep

# 命题「仅会话」临时快照（由 RPC 二次拉取后删除）
data/generation-scratch/*.json
!data/generation-scratch/.gitkeep

# 设置页保存的本机 MySQL 连接（含密码）
data/mysql-connection.json
data/mysql-password-master.key

# 网上导入队列（无 Supabase/MySQL 时的服务端回退文件）
data/remote-import-jobs.json

# 一类｜试卷数学残串自学规则（服务端合并进修复链）
data/exam-math-repair-overrides.json

# GOT-OCR HF 权重（npm run got-ocr:download-model，勿提交大文件）
data/hf-models/GOT-OCR-2.0-hf/**
!data/hf-models/.gitkeep

# 线下导入附图的运行时落盘（保留目录占位）
apps/web/public/import-figures/**
!apps/web/public/import-figures/.gitkeep

