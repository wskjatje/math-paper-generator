  "build": {
    "appId": "app.zhixue.math-paper-generator",
    "productName": "知学试卷",
    "copyright": "Copyright © zhixue",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/main.mjs",
      "package.json"
    ],
    "asar": true,
    "extraResources": [
      {
        "from": "dist",
        "to": "app-root/dist"
      },
      {
        "from": "node_modules",
        "to": "app-root/node_modules"
      },
      {
        "from": "package.json",
        "to": "app-root/package.json"
      },
      {
        "from": "vite.config.ts",
        "to": "app-root/vite.config.ts"
      }
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
